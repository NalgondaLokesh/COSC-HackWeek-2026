# Groq API Key
# Get your free API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Server Configuration
PORT=8000

# Model Configuration
# Available models: llama-3.3-70b-versatile, mixtral-8x7b-32768, llama-3.1-70b-versatile, llama-3.1-8b-instant
MODEL_NAME=llama-3.3-70b-versatile

# Document Processing Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=3
